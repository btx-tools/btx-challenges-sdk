{
  "name": "btx-challenges-sdk-workspace",
  "private": true,
  "version": "0.0.1",
  "description": "BTX service-challenges SDK — workspace root (private; publishable packages live in packages/*)",
  "author": "visitor-code <visitor@friction.market>",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:unit": "pnpm -r --filter './packages/*' test -- --project unit",
    "type-check": "pnpm -r type-check",
    "docs": "typedoc",
    "docs:watch": "typedoc --watch",
    "format": "prettier --write \"packages/**/*.{ts,json,md}\" \"*.{json,md,yml,yaml}\"",
    "clean": "pnpm -r exec rm -rf dist node_modules .turbo docs-site"
  },
  "devDependencies": {
    "prettier": "^3.3.0",
    "typedoc": "^0.28.19"
  },
  "engines": {
    "node": ">=18.17",
    "pnpm": ">=10"
  }
}
