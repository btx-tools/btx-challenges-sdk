{
  "name": "@btx/challenges-sdk",
  "version": "0.0.1",
  "description": "TypeScript SDK for BTX service challenges — chain-anchored proof-of-work admission control for APIs, agent gateways, and form submissions",
  "author": "visitor-code <visitor@friction.market>",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:smoke": "vitest run tests/smoke.test.ts",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prettier": "^3.3.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "keywords": [
    "btx",
    "service-challenges",
    "matmul",
    "post-quantum",
    "captcha",
    "admission",
    "rate-limit",
    "ai-gating",
    "agent",
    "mcp",
    "proof-of-work"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/btx-tools/btx-challenges-sdk.git"
  },
  "engines": {
    "node": ">=18"
  }
}
