{
  "name": "@btx-tools/browser-miner",
  "version": "0.1.0",
  "description": "Pool-agnostic browser mining client for BTX matmul service-challenge shares (WebGPU → WASM → pure-JS)",
  "author": "visitor-code <visitor@friction.market>",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "@btx-tools/challenges-sdk": "^1.4.0"
  },
  "optionalDependencies": {
    "@btx-tools/matmul-webgpu": "workspace:^",
    "@btx-tools/matmul-wasm": "^0.1.0"
  },
  "devDependencies": {
    "@btx-tools/challenges-sdk": "workspace:*",
    "@types/node": "^22.0.0",
    "@webgpu/types": "^0.1.40",
    "prettier": "^3.3.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "keywords": [
    "btx",
    "mining",
    "webgpu",
    "browser",
    "service-challenge",
    "proof-of-work"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/btx-tools/btx-challenges-sdk.git",
    "directory": "packages/browser-miner"
  },
  "homepage": "https://github.com/btx-tools/btx-challenges-sdk/tree/main/packages/browser-miner#readme",
  "bugs": {
    "url": "https://github.com/btx-tools/btx-challenges-sdk/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
