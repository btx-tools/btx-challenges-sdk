# Pointed at any reachable btxd with the service-challenge RPCs (v0.30.1+).
BTX_RPC_URL=http://127.0.0.1:19334
BTX_RPC_AUTH=rpcuser:rpcpass

# Server listen port. Default 3000. Match this in the client's GATE_URL below.
PORT=3000

# Client points at the same host:port the server listens on.
GATE_URL=http://127.0.0.1:3000/v1/generate

# Browser example (03-browser-solver) defaults to localhost:5173. Whitelist
# whatever origin you'll hit the gate from. Comma-separated for multiple.
CORS_ORIGIN=http://localhost:5173
