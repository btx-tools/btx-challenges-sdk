# Required — any btxd reachable on this URL with these credentials.
# For local dev, point at your own btxd's RPC port (default 19334).
# For a remote btxd over SSH tunnel: `ssh -L 19334:127.0.0.1:19334 <host>`
BTX_RPC_URL=http://127.0.0.1:19334
BTX_RPC_AUTH=rpcuser:rpcpass

# Optional — only set if you have a DEDICATED non-mining btxd reachable here.
# When set, the example runs an additional Solver.solve({ mode: 'rpc' }) demo.
# When unset, only pure-JS solving is demonstrated.
#
# Why dedicated: btxd shares the matmul backend between block mining and the
# solvematmulservicechallenge RPC. On a mining-loaded node, RPC-mode solving
# queues behind block work and can take 15+ minutes per solve.
#
# BTX_RPC_URL_DEDICATED=http://127.0.0.1:19334
# BTX_RPC_AUTH_DEDICATED=rpcuser:rpcpass
